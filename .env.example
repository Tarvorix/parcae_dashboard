# ── SEC EDGAR identity (required by EDGAR ToS) ───────────────────────────────
# Format: "Your Name your@email.com"
SEC_IDENTITY=Tarvorix Tarvorix@users.noreply.github.com

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default):
DATABASE_URL=sqlite:///./parcae.db

# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/parcae

# ── Frontend API base (dev only, Vite proxy handles Docker) ──────────────────
VITE_API_BASE=http://localhost:8000
